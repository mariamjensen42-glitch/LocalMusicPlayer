<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalMusicPlayer.ViewModels"
             xmlns:models="using:LocalMusicPlayer.Models"
             xmlns:converters="using:LocalMusicPlayer.Converters"
             xmlns:behaviors="using:LocalMusicPlayer.Behaviors"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="LocalMusicPlayer.Views.Library.HomeView"
             x:DataType="vm:HomeViewModel"
             x:CompileBindings="False">

    <UserControl.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />
        <converters:AlbumArtConverter x:Key="AlbumArtConverter" />
        <converters:SongIsPlayingConverter x:Key="SongIsPlayingConverter" />
        <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="*" Margin="32,32,32,0">
        <Border Grid.Row="0"
                Background="{StaticResource BgCardBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                Margin="0,16,0,32"
                IsVisible="{Binding !IsGridView}">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        Height="40"
                        Padding="12,0,12,0"
                        Background="{StaticResource BgTableHeaderBrush}"
                        CornerRadius="12,12,0,0">
                    <Grid ColumnDefinitions="48,44,*,200,56,64"
                          VerticalAlignment="Center">
                        <TextBlock Grid.Column="0"
                                   Text="#"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Column="1"
                                   Text=""
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Column="2"
                                   Text="{DynamicResource StringTitle} &amp; {DynamicResource StringArtist}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock Grid.Column="3"
                                   Text="{DynamicResource StringAlbum}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock Grid.Column="4"
                                   Text=""
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Column="5"
                                   Text="{DynamicResource StringDuration}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0" />
                    </Grid>
                </Border>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Songs}"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionMode="Multiple">
                    <ListBox.ItemContainerTheme>
                        <ControlTheme TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Style Selector="^:pointerover">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Style Selector="^:selected">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                            <Style Selector="^:pressed">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Setter Property="Template">
                                <ControlTemplate>
                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}" />
                                </ControlTemplate>
                            </Setter>
                        </ControlTheme>
                    </ListBox.ItemContainerTheme>

                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Song">
                            <Border Theme="{StaticResource SongListItemRowTheme}"
                                    Margin="0,2,0,4"
                                    Cursor="Hand">
                                <i:Interaction.Behaviors>
                                    <behaviors:TapCommandBehavior
                                        Command="{Binding $parent[ListBox].DataContext.PlaySongCommand}"
                                        CommandParameter="{Binding FilePath}" />
                                </i:Interaction.Behaviors>

                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{DynamicResource StringEditInfo}"
                                                  Command="{Binding $parent[ListBox].DataContext.EditSongMetadataCommand}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons" FontSize="12" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="{DynamicResource StringBatchEdit}"
                                                  Command="{Binding $parent[ListBox].DataContext.BatchEditMetadataCommand}"
                                                  CommandParameter="{Binding $parent[ListBox].SelectedItems}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE8AC;" FontFamily="Segoe Fluent Icons" FontSize="12" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator />
                                        <MenuItem Header="{DynamicResource StringAddToPlaylist}"
                                                  Command="{Binding $parent[ListBox].DataContext.AddToPlaylistCommand}"
                                                  CommandParameter="{Binding FilePath}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="12" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <Grid ColumnDefinitions="48,44,*,200,56,64"
                                      VerticalAlignment="Center">
                                    <Grid Grid.Column="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TrackNumber}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.IsVisible>
                                                <MultiBinding Converter="{StaticResource SongIsPlayingConverter}"
                                                              ConverterParameter="invert">
                                                    <Binding Path="FilePath" />
                                                    <Binding
                                                        Path="$parent[ListBox].DataContext.CurrentSong.FilePath"
                                                        FallbackValue="" />
                                                    <Binding Path="$parent[ListBox].DataContext.IsPlaying"
                                                             FallbackValue="False" />
                                                </MultiBinding>
                                            </TextBlock.IsVisible>
                                        </TextBlock>

                                        <TextBlock Text="&#xE768;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.IsVisible>
                                                <MultiBinding Converter="{StaticResource SongIsPlayingConverter}">
                                                    <Binding Path="FilePath" />
                                                    <Binding
                                                        Path="$parent[ListBox].DataContext.CurrentSong.FilePath"
                                                        FallbackValue="" />
                                                    <Binding Path="$parent[ListBox].DataContext.IsPlaying"
                                                             FallbackValue="False" />
                                                </MultiBinding>
                                            </TextBlock.IsVisible>
                                        </TextBlock>
                                    </Grid>

                                    <Border Grid.Column="1"
                                            Width="40"
                                            Height="40"
                                            CornerRadius="6"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource BgElement2Brush}"
                                            ClipToBounds="True">
                                        <Image
                                            Source="{Binding AlbumArtPath, Converter={StaticResource AlbumArtConverter}}"
                                            Stretch="UniformToFill" />
                                    </Border>

                                    <StackPanel Grid.Column="2"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center"
                                                Spacing="4">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis">
                                            <TextBlock.Foreground>
                                                <MultiBinding Converter="{StaticResource SongIsPlayingConverter}">
                                                    <Binding Path="FilePath" />
                                                    <Binding
                                                        Path="$parent[ListBox].DataContext.CurrentSong.FilePath"
                                                        FallbackValue="" />
                                                    <Binding Path="$parent[ListBox].DataContext.IsPlaying"
                                                             FallbackValue="False" />
                                                </MultiBinding>
                                            </TextBlock.Foreground>
                                        </TextBlock>

                                        <TextBlock Text="{Binding Artist}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Album}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0" />

                                    <Button Grid.Column="4"
                                            Theme="{StaticResource TransparentIconButtonTheme}"
                                            Command="{Binding $parent[ListBox].DataContext.ToggleFavoriteCommand}"
                                            CommandParameter="{Binding FilePath}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Padding="8">
                                        <Grid>
                                            <TextBlock Text="&#xE87C;"
                                                       FontFamily="Segoe Fluent Icons"
                                                       FontSize="16"
                                                       Foreground="{StaticResource HeartInactiveBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       IsVisible="{Binding IsFavorite, Converter={StaticResource BoolToColorConverter}, ConverterParameter=invert|invert}" />

                                            <TextBlock Text="&#xE87D;"
                                                       FontFamily="Segoe Fluent Icons"
                                                       FontSize="16"
                                                       Foreground="{StaticResource AccentPinkBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       IsVisible="{Binding IsFavorite}" />
                                        </Grid>
                                    </Button>

                                    <TextBlock Grid.Column="5"
                                               Text="{Binding Duration, Converter={StaticResource TimeSpanToStringConverter}}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"
                                               FontFamily="{StaticResource FontFamilyMono}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="1"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      IsVisible="{Binding Songs.Count, Converter={StaticResource CountToBoolConverter}, ConverterParameter=invert}">
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8D6;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="48"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{DynamicResource StringNoSongs}"
                                   FontSize="16"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{DynamicResource StringAddMusicFolder}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,16,0,32"
                      IsVisible="{Binding IsGridView}">
            <ItemsControl ItemsSource="{Binding Songs}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:Song">
                        <Border Background="{StaticResource BgCardBrush}"
                                CornerRadius="12"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1"
                                Margin="0,0,16,16"
                                Width="180"
                                Cursor="Hand">
                            <i:Interaction.Behaviors>
                                <behaviors:TapCommandBehavior
                                    Command="{Binding $parent[ItemsControl].DataContext.PlaySongCommand}"
                                    CommandParameter="{Binding FilePath}" />
                            </i:Interaction.Behaviors>
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource StringEditInfo}"
                                              Command="{Binding $parent[ItemsControl].DataContext.EditSongMetadataCommand}"
                                              CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons" FontSize="12" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="{DynamicResource StringAddToPlaylist}"
                                              Command="{Binding $parent[ItemsControl].DataContext.AddToPlaylistCommand}"
                                              CommandParameter="{Binding FilePath}">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="12" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <StackPanel Spacing="8" Margin="12">
                                <Border Width="156"
                                        Height="156"
                                        CornerRadius="8"
                                        Background="{StaticResource BgElement2Brush}"
                                        ClipToBounds="True">
                                    <Image Source="{Binding AlbumArtPath, Converter={StaticResource AlbumArtConverter}}"
                                           Stretch="UniformToFill" />
                                </Border>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Artist}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Album}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Duration, Converter={StaticResource TimeSpanToStringConverter}}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontFamily="{StaticResource FontFamilyMono}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="1"
              IsVisible="{Binding IsGridEmptyVisible}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="0,64,0,32">
            <StackPanel Spacing="16" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8D6;"
                           FontFamily="Segoe Fluent Icons"
                           FontSize="48"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{DynamicResource StringNoSongs}"
                           FontSize="16"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{DynamicResource StringAddMusicFolder}"
                           FontSize="13"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
