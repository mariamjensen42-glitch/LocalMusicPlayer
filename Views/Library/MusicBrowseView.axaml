<UserControl
    x:Class="LocalMusicPlayer.Views.Library.MusicBrowseView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:LocalMusicPlayer.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:LocalMusicPlayer.ViewModels"
    d:DesignHeight="900"
    d:DesignWidth="1200"
    x:CompileBindings="False"
    x:DataType="vm:MusicBrowseViewModel"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />
        <converters:AlbumArtConverter x:Key="AlbumArtConverter" />
        <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
        <converters:PlayModeToIconConverter x:Key="PlayModeToIconConverter" />
        <converters:VolumeToIconConverter x:Key="VolumeToIconConverter" />
        <converters:FavouriteIconConverter x:Key="FavouriteIconConverter" />
        <converters:PlayStatusToIconConverter x:Key="PlayStatusToIconConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto">
        <!--  顶部区域 - 标签导航和工具栏  -->
        <Grid Grid.Row="0" Margin="48,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  标签导航栏  -->
            <StackPanel
                Grid.Row="0"
                Margin="5,32,0,16"
                Orientation="Horizontal"
                Spacing="8">

                <RadioButton
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="song"
                    Content="{DynamicResource StringTabSong}"
                    GroupName="TabNavigation"
                    IsChecked="{Binding SelectedTab, ConverterParameter=song, Mode=OneWay}"
                    Tag="song"
                    Theme="{StaticResource TabRadioButtonTheme}" />

                <RadioButton
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="album"
                    Content="{DynamicResource StringTabAlbum}"
                    GroupName="TabNavigation"
                    IsChecked="{Binding SelectedTab, ConverterParameter=album, Mode=OneWay}"
                    Tag="album"
                    Theme="{StaticResource TabRadioButtonTheme}" />

                <RadioButton
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="artist"
                    Content="{DynamicResource StringTabArtist}"
                    GroupName="TabNavigation"
                    IsChecked="{Binding SelectedTab, ConverterParameter=artist, Mode=OneWay}"
                    Tag="artist"
                    Theme="{StaticResource TabRadioButtonTheme}" />

                <RadioButton
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="folder"
                    Content="{DynamicResource StringTabFolder}"
                    GroupName="TabNavigation"
                    IsChecked="{Binding SelectedTab, ConverterParameter=folder, Mode=OneWay}"
                    Tag="folder"
                    Theme="{StaticResource TabRadioButtonTheme}" />

                <RadioButton
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="favourite"
                    Content="{DynamicResource StringTabFavourite}"
                    GroupName="TabNavigation"
                    IsChecked="{Binding SelectedTab, ConverterParameter=favourite, Mode=OneWay}"
                    Tag="favourite"
                    Theme="{StaticResource TabRadioButtonTheme}" />

                <RadioButton
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="playlist"
                    Content="{DynamicResource StringTabPlaylist}"
                    GroupName="TabNavigation"
                    IsChecked="{Binding SelectedTab, ConverterParameter=playlist, Mode=OneWay}"
                    Tag="playlist"
                    Theme="{StaticResource TabRadioButtonTheme}" />

            </StackPanel>

            <!--  工具栏 (可选)  -->
            <StackPanel
                Grid.Row="1"
                Margin="10,0,10,8"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12">

                <Border
                    Width="20"
                    Height="20"
                    Background="{StaticResource AccentPurpleBrush}"
                    CornerRadius="10"
                    IsVisible="{Binding IsLoading}" />

                <ComboBox
                    Width="130"
                    VerticalAlignment="Center"
                    ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="12" Text="{Binding DisplayText}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBox
                    Width="200"
                    Text="{Binding SearchText, Mode=TwoWay}"
                    Watermark="{DynamicResource StringSearchMusic}" />

            </StackPanel>
        </Grid>

        <!--  中间内容区域  -->
        <ContentControl
            Grid.Row="1"
            Margin="10"
            Content="{Binding CurrentContent}" />

        <!--  底部播放控制栏  -->
        <Border
            Grid.Row="2"
            Height="120"
            Margin="10,0,10,10"
            Background="{StaticResource PlayerBarBgBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="12">

            <Grid Margin="16,12" RowDefinitions="Auto,*">
                <!--  进度条和时间显示  -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Slider
                        Grid.Column="0"
                        Maximum="{Binding DurationSeconds}"
                        Minimum="0"
                        Theme="{StaticResource MusicProgressSliderTheme}"
                        Value="{Binding PositionSeconds, Mode=TwoWay}" />

                    <TextBlock
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource FontFamilyMono}"
                        FontSize="12"
                        Foreground="{StaticResource TextMutedBrush}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} / {1}">
                                <Binding Converter="{StaticResource TimeSpanToStringConverter}" Path="Position" />
                                <Binding Converter="{StaticResource TimeSpanToStringConverter}" Path="Duration" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>

                <!--  播放控制区域  -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  左列 - 当前播放信息  -->
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="12">

                        <!--  封面图片按钮  -->
                        <Button
                            Padding="0"
                            Command="{Binding ShowCurrentSongDetailCommand}"
                            CornerRadius="5"
                            Theme="{StaticResource TransparentIconButtonTheme}">
                            <Border
                                Width="80"
                                Height="80"
                                Background="{StaticResource BgElement2Brush}"
                                ClipToBounds="True"
                                CornerRadius="5">
                                <Image Source="{Binding CurrentSong.AlbumArtPath, Converter={StaticResource AlbumArtConverter}}" Stretch="UniformToFill" />
                            </Border>
                        </Button>

                        <!--  歌曲信息  -->
                        <Grid
                            Height="80"
                            MaxWidth="300"
                            VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Margin="10,0,10,0"
                                FontSize="18"
                                FontWeight="Bold"
                                Text="{Binding CurrentSong.Title}"
                                TextTrimming="CharacterEllipsis" />

                            <Button
                                Grid.Row="1"
                                Margin="10,0,10,0"
                                Padding="1"
                                VerticalAlignment="Bottom"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding NavigateToAlbumCommand}"
                                CommandParameter="{Binding CurrentSong.Album}"
                                Theme="{StaticResource NoHoverButtonTheme}">
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="{Binding CurrentSong.Album}"
                                    TextTrimming="WordEllipsis" />
                            </Button>

                            <Button
                                Grid.Row="2"
                                Margin="10,0,10,0"
                                Padding="1"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding NavigateToArtistCommand}"
                                CommandParameter="{Binding CurrentSong.Artist}"
                                Theme="{StaticResource NoHoverButtonTheme}">
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="{Binding CurrentSong.Artist}"
                                    TextTrimming="WordEllipsis" />
                            </Button>

                            <StackPanel
                                Grid.Row="3"
                                Margin="10,0,10,0"
                                VerticalAlignment="Bottom"
                                Orientation="Horizontal"
                                Spacing="6">
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    Text="{Binding CurrentSong.AudioInfo}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!--  中列 - 播放控制按钮组  -->
                    <Grid
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  收藏按钮  -->
                        <Button
                            Grid.Column="0"
                            Margin="3"
                            Command="{Binding ToggleFavoriteCommand}"
                            CommandParameter="{Binding CurrentSong.FilePath}"
                            Theme="{StaticResource PlayerControlButtonTheme}">
                            <Grid>
                                <TextBlock
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Foreground="{StaticResource HeartInactiveBrush}"
                                    IsVisible="{Binding CurrentSong.IsFavorite, Converter={StaticResource BoolToColorConverter}, ConverterParameter=invert|invert}"
                                    Text="&#xE87C;" />

                                <TextBlock
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Foreground="{StaticResource AccentPinkBrush}"
                                    IsVisible="{Binding CurrentSong.IsFavorite}"
                                    Text="&#xE87D;" />
                            </Grid>
                        </Button>

                        <!--  快退按钮 (-5秒)  -->
                        <Button
                            Grid.Column="1"
                            Margin="5"
                            Command="{Binding FastBackwardCommand}"
                            Theme="{StaticResource PlayerControlButtonTheme}">
                            <TextBlock
                                FontFamily="Segoe Fluent Icons"
                                FontSize="18"
                                Text="&#xE9E9;" />
                        </Button>

                        <!--  上一曲按钮  -->
                        <Button
                            Grid.Column="2"
                            Margin="5"
                            Command="{Binding PreviousCommand}"
                            Theme="{StaticResource PlayerControlButtonTheme}">
                            <TextBlock
                                FontFamily="Segoe Fluent Icons"
                                FontSize="22"
                                Text="&#xE892;" />
                        </Button>

                        <!--  播放/暂停按钮 (大按钮)  -->
                        <Button
                            Grid.Column="3"
                            Margin="5"
                            Command="{Binding PlayCommand}"
                            Theme="{StaticResource PlayButtonLargeTheme}">
                            <TextBlock
                                FontFamily="Segoe Fluent Icons"
                                FontSize="24"
                                Foreground="White"
                                Text="{Binding IsPlaying, Converter={StaticResource PlayStatusToIconConverter}}" />
                        </Button>

                        <!--  下一曲按钮  -->
                        <Button
                            Grid.Column="4"
                            Margin="5"
                            Command="{Binding NextCommand}"
                            Theme="{StaticResource PlayerControlButtonTheme}">
                            <TextBlock
                                FontFamily="Segoe Fluent Icons"
                                FontSize="22"
                                Text="&#xE893;" />
                        </Button>

                        <!--  快进按钮 (+5秒)  -->
                        <Button
                            Grid.Column="5"
                            Margin="5"
                            Command="{Binding FastForwardCommand}"
                            Theme="{StaticResource PlayerControlButtonTheme}">
                            <TextBlock
                                FontFamily="Segoe Fluent Icons"
                                FontSize="18"
                                Text="&#xEB9D;" />
                        </Button>

                        <!--  停止按钮  -->
                        <Button
                            Grid.Column="6"
                            Margin="3"
                            Command="{Binding StopCommand}"
                            Theme="{StaticResource PlayerControlButtonTheme}">
                            <TextBlock
                                FontFamily="Segoe Fluent Icons"
                                FontSize="18"
                                Text="&#xE71A;" />
                        </Button>
                    </Grid>

                    <!--  右列 - 其他控制  -->
                    <StackPanel
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">

                        <!--  均衡器按钮  -->
                        <Button Command="{Binding ShowEqualizerCommand}" Theme="{StaticResource PlayerControlButtonTheme}">
                            <TextBlock
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Text="&#xE9E9;" />
                        </Button>

                        <!--  当前播放列表按钮  -->
                        <Button Command="{Binding ShowPlaylistCommand}" Theme="{StaticResource PlayerControlButtonTheme}">
                            <TextBlock
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Text="&#xE90B;" />
                        </Button>

                        <!--  播放模式按钮  -->
                        <Button
                            Margin="10,0,0,0"
                            Command="{Binding PlayModeChangedCommand}"
                            Theme="{StaticResource PlayerControlButtonTheme}">
                            <TextBlock
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Text="{Binding PlaybackMode, Converter={StaticResource PlayModeToIconConverter}}" />
                        </Button>

                        <!--  音量图标  -->
                        <Button Command="{Binding MuteToggleCommand}" Theme="{StaticResource PlayerControlButtonTheme}">
                            <TextBlock
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Text="{Binding Volume, Converter={StaticResource VolumeToIconConverter}}" />
                        </Button>

                        <!--  音量滑块  -->
                        <Slider
                            Width="100"
                            Maximum="100"
                            Minimum="0"
                            Theme="{StaticResource VolumeControlSliderTheme}"
                            Value="{Binding Volume, Mode=TwoWay}" />

                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
