<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalMusicPlayer.ViewModels"
             xmlns:models="using:LocalMusicPlayer.Models"
             xmlns:converters="using:LocalMusicPlayer.Converters"
             xmlns:behaviors="using:LocalMusicPlayer.Behaviors"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
             x:Class="LocalMusicPlayer.Views.Library.SongListView"
             x:DataType="vm:SongListViewModel"
             x:CompileBindings="False">

    <UserControl.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />
        <converters:AlbumArtConverter x:Key="AlbumArtConverter" />
        <converters:SongIsPlayingConverter x:Key="SongIsPlayingConverter" />
        <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
        <converters:CountToBoolConverter x:Key="CountToBoolConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="*" Margin="32,32,32,0">
        <Border Grid.Row="0"
                Background="{StaticResource BgCardBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                Margin="0,16,0,32">
            <Grid RowDefinitions="Auto,*">
                <!-- 表头行 -->
                <Border Grid.Row="0"
                        Height="40"
                        Padding="12,0,12,0"
                        Background="{StaticResource BgTableHeaderBrush}"
                        CornerRadius="12,12,0,0">
                    <Grid ColumnDefinitions="48,44,*,200,56,64,44,44"
                          VerticalAlignment="Center">
                        <TextBlock Grid.Column="0"
                                   Text="#"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Column="1"
                                   Text=""
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Column="2"
                                   Text="{DynamicResource StringTitle} &amp; {DynamicResource StringArtist}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock Grid.Column="3"
                                   Text="{DynamicResource StringAlbum}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock Grid.Column="4"
                                   Text=""
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Column="5"
                                   Text="{DynamicResource StringDuration}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0" />

                        <TextBlock Grid.Column="6"
                                   Text=""
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Column="7"
                                   Text=""
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- 数据列表 -->
                <ListBox x:Name="SongList"
                         Grid.Row="1"
                         ItemsSource="{Binding Songs}"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionMode="Multiple"
                         SelectedItems="{Binding SelectedSongs}">
                    <ListBox.ItemContainerTheme>
                        <ControlTheme TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Style Selector="^:pointerover">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Style Selector="^:selected">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                            <Style Selector="^:pressed">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Setter Property="Template">
                                <ControlTemplate>
                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}" />
                                </ControlTemplate>
                            </Setter>
                        </ControlTheme>
                    </ListBox.ItemContainerTheme>

                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Song">
                            <Border Theme="{StaticResource SongListItemRowTheme}"
                                    Margin="0,2,0,4"
                                    Cursor="Hand">
                                <i:Interaction.Behaviors>
                                    <behaviors:TapCommandBehavior
                                        Command="{Binding $parent[ListBox].DataContext.PlayCommand}"
                                        CommandParameter="{Binding}" />
                                </i:Interaction.Behaviors>

                                <Border.ContextMenu>
                                    <ContextMenu ItemsSource="{Binding $parent[ListBox].DataContext.MenuOptions}">
                                        <ContextMenu.ItemTemplate>
                                            <DataTemplate x:DataType="vm:MenuOption">
                                                <MenuItem Header="{Binding Title}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="&#xE710;"
                                                                   FontFamily="Segoe Fluent Icons"
                                                                   FontSize="12" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </DataTemplate>
                                        </ContextMenu.ItemTemplate>
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <Grid ColumnDefinitions="48,44,*,200,56,64,44,44"
                                      VerticalAlignment="Center">
                                    <!-- Column 0 - 封面缩略图 / 播放图标 -->
                                    <Grid Grid.Column="0"
                                          Width="40"
                                          Height="40"
                                          CornerRadius="6"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          ClipToBounds="True">
                                        <Image Source="{Binding AlbumArtPath, Converter={StaticResource AlbumArtConverter}}"
                                               Stretch="UniformToFill" />

                                        <!-- 播放图标（当前播放时显示） -->
                                        <Border Background="#CC000000"
                                                CornerRadius="6"
                                                IsVisible="{Binding FilePath, Converter={StaticResource SongIsPlayingConverter}, ConverterParameter=playicon|$parent[ListBox].DataContext.CurrentSong.FilePath|$parent[ListBox].DataContext.IsPlaying}">
                                            <Grid HorizontalAlignment="Center"
                                                  VerticalAlignment="Center">
                                                <TextBlock Text="&#xE768;"
                                                           FontFamily="Segoe Fluent Icons"
                                                           FontSize="14"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <!-- Column 1 - 收藏图标 -->
                                    <Button Grid.Column="1"
                                            Theme="{StaticResource TransparentIconButtonTheme}"
                                            Command="{Binding $parent[ListBox].DataContext.ToggleFavoriteCommand}"
                                            CommandParameter="{Binding FilePath}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Padding="8">
                                        <Grid>
                                            <TextBlock Text="&#xE87C;"
                                                       FontFamily="Segoe Fluent Icons"
                                                       FontSize="16"
                                                       Foreground="{StaticResource HeartInactiveBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       IsVisible="{Binding IsFavorite, Converter={StaticResource BoolToColorConverter}, ConverterParameter=invert|invert}" />

                                            <TextBlock Text="&#xE87D;"
                                                       FontFamily="Segoe Fluent Icons"
                                                       FontSize="16"
                                                       Foreground="{StaticResource AccentPinkBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       IsVisible="{Binding IsFavorite}" />
                                        </Grid>
                                    </Button>

                                    <!-- Column 2 - 标题和艺人 -->
                                    <StackPanel Grid.Column="2"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center"
                                                Spacing="4">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis">
                                            <TextBlock.Foreground>
                                                <MultiBinding Converter="{StaticResource SongIsPlayingConverter}">
                                                    <Binding Path="FilePath" />
                                                    <Binding Path="$parent[ListBox].DataContext.CurrentSong.FilePath"
                                                             FallbackValue="" />
                                                    <Binding Path="$parent[ListBox].DataContext.IsPlaying"
                                                             FallbackValue="False" />
                                                </MultiBinding>
                                            </TextBlock.Foreground>
                                        </TextBlock>

                                        <TextBlock Text="{Binding Artist}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <!-- Column 3 - 专辑 -->
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Album}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0">
                                        <i:Interaction.Behaviors>
                                            <behaviors:TapCommandBehavior
                                                Command="{Binding $parent[ListBox].DataContext.NavigateToAlbumCommand}"
                                                CommandParameter="{Binding Album}" />
                                        </i:Interaction.Behaviors>
                                    </TextBlock>

                                    <!-- Column 4 - 音质标识（预留） -->
                                    <Border Grid.Column="4"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding HasHiResAudio}">
                                        <TextBlock Text="HR"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentPinkBrush}"
                                                   Background="{StaticResource BgElement2Brush}"
                                                   Padding="4,2"
                                                   CornerRadius="4" />
                                    </Border>

                                    <!-- Column 5 - 时长 -->
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding Duration, Converter={StaticResource TimeSpanToStringConverter}}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"
                                               FontFamily="{StaticResource FontFamilyMono}" />

                                    <!-- Column 6 - 添加到播放队列 -->
                                    <Button Grid.Column="6"
                                            Theme="{StaticResource TransparentIconButtonTheme}"
                                            Command="{Binding $parent[ListBox].DataContext.AddToCurrentPlayListCommand}"
                                            CommandParameter="{Binding}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Padding="8"
                                            ToolTip.Tip="{DynamicResource StringAddToPlaylist}">
                                        <TextBlock Text="&#xE710;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="16"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" />
                                    </Button>

                                    <!-- Column 7 - 设备状态 -->
                                    <Border Grid.Column="7"
                                            Width="20"
                                            Height="20"
                                            CornerRadius="10"
                                            Background="{StaticResource SuccessGreenBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding ExistsOnDevice}"
                                            ToolTip.Tip="{DynamicResource StringAvailableOnDevice}">
                                        <TextBlock Text="&#xE73E;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="12"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <Border Grid.Column="7"
                                            Width="20"
                                            Height="20"
                                            CornerRadius="10"
                                            Background="{StaticResource ErrorRedBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding ExistsOnDevice, Converter={StaticResource BoolToColorConverter}, ConverterParameter=invert|invert}"
                                            ToolTip.Tip="{DynamicResource StringNotAvailableOnDevice}">
                                        <TextBlock Text="&#xE74D;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="12"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 空状态提示 -->
                <Grid Grid.Row="1"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      IsVisible="{Binding Songs.Count, Converter={StaticResource CountToBoolConverter}, ConverterParameter=invert}">
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8D6;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="48"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{DynamicResource StringNoSongs}"
                                   FontSize="16"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{DynamicResource StringAddMusicFolder}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
