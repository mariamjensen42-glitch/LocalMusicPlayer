<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalMusicPlayer.ViewModels"
             xmlns:models="using:LocalMusicPlayer.Models"
             xmlns:converters="using:LocalMusicPlayer.Converters"
             xmlns:behaviors="using:LocalMusicPlayer.Behaviors"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="LocalMusicPlayer.Views.Library.AlbumsPageView"
             x:DataType="vm:AlbumsPageViewModel"
             x:CompileBindings="True">

    <UserControl.Resources>
        <converters:AlbumArtConverter x:Key="AlbumArtConverter" />
        <converters:CountToBoolConverter x:Key="CountToBoolConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <TextBlock Text="{DynamicResource StringAlbums}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
        </Border>

        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding AlbumGroups}"
                          Margin="24,20">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:AlbumGroup">
                        <Border Background="{StaticResource BgCardBrush}"
                                CornerRadius="12"
                                Margin="0,0,16,16"
                                Width="180"
                                Cursor="Hand">
                            <i:Interaction.Behaviors>
                                <behaviors:TapCommandBehavior
                                    Command="{Binding $parent[ItemsControl].DataContext.SelectItemCommand}"
                                    CommandParameter="{Binding}" />
                            </i:Interaction.Behaviors>
                            <StackPanel Spacing="8" Margin="12">
                                <Border Width="156"
                                        Height="156"
                                        CornerRadius="8"
                                        Background="{StaticResource BgElement2Brush}">
                                    <Image Source="{Binding CoverArtPath, Converter={StaticResource AlbumArtConverter}}"
                                           Stretch="UniformToFill" />
                                </Border>
                                <TextBlock Text="{Binding AlbumName}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding ArtistName}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding SongCount, StringFormat={}{0} 首}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
