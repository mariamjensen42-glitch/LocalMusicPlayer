<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalMusicPlayer.ViewModels"
             xmlns:models="using:LocalMusicPlayer.Models"
             xmlns:converters="using:LocalMusicPlayer.Converters"
             xmlns:behaviors="using:LocalMusicPlayer.Behaviors"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="LocalMusicPlayer.Views.Library.LibraryBrowserView"
             x:DataType="vm:LibraryBrowserViewModel">

    <Design.DataContext>
        <vm:LibraryBrowserViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />
        <converters:CountToBoolConverter x:Key="CountToBoolConverter" />
        <converters:AlbumArtConverter x:Key="AlbumArtConverter" />
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
        <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0"
                    Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="24,16">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding CurrentCategory}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <Border Grid.Column="1"
                            Background="{StaticResource BgInputBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Width="280">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding SearchText, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="12,8"
                                     Watermark="Search..." />
                            <Button Grid.Column="1"
                                    Theme="{StaticResource TransparentIconButtonTheme}"
                                    Command="{Binding ClearSearchCommand}"
                                    IsVisible="{Binding SearchText, Converter={StaticResource StringNotEmptyConverter}}">
                                <TextBlock Text="&#xE711;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1">
                <StackPanel Margin="24,20">
                    <ItemsControl ItemsSource="{Binding Songs}"
                                  IsVisible="{Binding CurrentCategory, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:BrowserCategory.Songs}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Song">
                                <Border Background="Transparent"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16,12"
                                        Cursor="Hand">
                                    <i:Interaction.Behaviors>
                                        <behaviors:TapCommandBehavior
                                            Command="{Binding $parent[ItemsControl].DataContext.SelectItemCommand}"
                                            CommandParameter="{Binding}" />
                                    </i:Interaction.Behaviors>
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                        <Border Grid.Column="0"
                                                Width="48"
                                                Height="48"
                                                CornerRadius="8"
                                                Background="{StaticResource BgElement2Brush}">
                                            <Image
                                                Source="{Binding AlbumArtPath, Converter={StaticResource AlbumArtConverter}}"
                                                Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="14"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding Artist}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Album}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,24,0" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Duration, Converter={StaticResource TimeSpanToStringConverter}}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{StaticResource FontFamilyMono}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding Artists}"
                                  IsVisible="{Binding CurrentCategory, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:BrowserCategory.Artists}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ArtistInfo">
                                <Border Background="{StaticResource BgCardBrush}"
                                        CornerRadius="12"
                                        Margin="0,0,16,16"
                                        Width="160"
                                        Cursor="Hand">
                                    <i:Interaction.Behaviors>
                                        <behaviors:TapCommandBehavior
                                            Command="{Binding $parent[ItemsControl].DataContext.SelectItemCommand}"
                                            CommandParameter="{Binding}" />
                                    </i:Interaction.Behaviors>
                                    <StackPanel Spacing="8" Margin="12">
                                        <Border Width="120"
                                                Height="120"
                                                CornerRadius="60"
                                                Background="{StaticResource BgElement2Brush}">
                                            <Image
                                                Source="{Binding CoverPath, Converter={StaticResource AlbumArtConverter}}"
                                                Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding SongCount, StringFormat='{}{0} songs'}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding Albums}"
                                  IsVisible="{Binding CurrentCategory, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:BrowserCategory.Albums}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:AlbumInfo">
                                <Border Background="{StaticResource BgCardBrush}"
                                        CornerRadius="12"
                                        Margin="0,0,16,16"
                                        Width="180"
                                        Cursor="Hand">
                                    <i:Interaction.Behaviors>
                                        <behaviors:TapCommandBehavior
                                            Command="{Binding $parent[ItemsControl].DataContext.SelectItemCommand}"
                                            CommandParameter="{Binding}" />
                                    </i:Interaction.Behaviors>
                                    <StackPanel Spacing="8" Margin="12">
                                        <Border Width="156"
                                                Height="156"
                                                CornerRadius="8"
                                                Background="{StaticResource BgElement2Brush}">
                                            <Image
                                                Source="{Binding CoverPath, Converter={StaticResource AlbumArtConverter}}"
                                                Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Artist}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Year, StringFormat='{}{0}'}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding Genres}"
                                  IsVisible="{Binding CurrentCategory, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:BrowserCategory.Genres}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:GenreInfo">
                                <Border Background="{StaticResource BgCardBrush}"
                                        CornerRadius="8"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                        BorderThickness="1"
                                        Margin="0,0,0,8"
                                        Padding="16"
                                        Cursor="Hand">
                                    <i:Interaction.Behaviors>
                                        <behaviors:TapCommandBehavior
                                            Command="{Binding $parent[ItemsControl].DataContext.SelectItemCommand}"
                                            CommandParameter="{Binding}" />
                                    </i:Interaction.Behaviors>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SongCount, StringFormat='{}{0} songs'}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TreeView ItemsSource="{Binding Folders}"
                              IsVisible="{Binding CurrentCategory, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:BrowserCategory.Folders}}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate x:DataType="models:FolderNode"
                                              ItemsSource="{Binding Children}">
                                <Border Padding="8,4"
                                        Cursor="Hand">
                                    <i:Interaction.Behaviors>
                                        <behaviors:TapCommandBehavior
                                            Command="{Binding $parent[TreeView].DataContext.SelectItemCommand}"
                                            CommandParameter="{Binding}" />
                                    </i:Interaction.Behaviors>
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="&#xE8B7;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="16"
                                                   Foreground="{StaticResource AccentPurpleBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding SongCount, StringFormat='{}{0} songs'}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0" />
                                    </Grid>
                                </Border>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>

