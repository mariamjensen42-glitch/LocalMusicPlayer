<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalMusicPlayer.ViewModels"
             xmlns:models="using:LocalMusicPlayer.Models"
             xmlns:views="using:LocalMusicPlayer.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="LocalMusicPlayer.Views.PlayerView"
             x:DataType="vm:MainWindowViewModel">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto">
        <!-- Main Content Area -->
        <Grid Grid.Row="0" RowDefinitions="Auto,*">
            <!-- Header Area -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="32,24,32,0">
                <!-- Left: Title and Stats -->
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{StaticResource String_Library}"
                               FontSize="32"
                               FontWeight="ExtraBold"
                               FontFamily="Inter"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding LibraryStats}"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <!-- Right: Play All Button -->
                <Button Grid.Column="1"
                        Height="38"
                        Command="{Binding PlayAllCommand}"
                        CornerRadius="8"
                        Padding="12,0"
                        Cursor="Hand"
                        VerticalAlignment="Top"
                        Background="{StaticResource PurplePinkVerticalGradientBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="&#xE768;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="14"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{StaticResource String_PlayAll}"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Song List Table Area -->
            <Grid Grid.Row="1" Margin="32,24,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Border Grid.Row="0"
                        Background="{StaticResource BgTableHeaderBrush}"
                        CornerRadius="8"
                        Padding="16,12"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        Margin="0,0,0,6">
                    <Grid ColumnDefinitions="30,*,180,70,60">
                        <TextBlock Grid.Column="0"
                                   Text="{StaticResource String_Number}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{StaticResource String_Title}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Grid.Column="2"
                                   Text="{StaticResource String_Album}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Grid.Column="3"
                                   Text="{StaticResource String_Duration}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Grid.Column="4"
                                   Text="{StaticResource String_Plays}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </Grid>
                </Border>

                <!-- Song List -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Library.FilteredSongs}"
                         SelectedItem="{Binding CurrentSong}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerTheme="{StaticResource SongListItemTheme}">
                    <ListBox.DataTemplates>
                        <DataTemplate DataType="models:Song">
                            <Border x:Name="SongRow"
                                    CornerRadius="8"
                                    Padding="16,12"
                                    BorderThickness="1">
                                <Border.Background>
                                    <MultiBinding Converter="{StaticResource SongIsPlayingConverter}">
                                        <Binding Path="." />
                                        <Binding
                                            Path="$parent[ListBox].((vm:MainWindowViewModel)DataContext).CurrentSong" />
                                    </MultiBinding>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <MultiBinding Converter="{StaticResource SongIsPlayingConverter}"
                                                  ConverterParameter="Border">
                                        <Binding Path="." />
                                        <Binding
                                            Path="$parent[ListBox].((vm:MainWindowViewModel)DataContext).CurrentSong" />
                                    </MultiBinding>
                                </Border.BorderBrush>
                                <Grid ColumnDefinitions="30,*,180,70,60,Auto,Auto">
                                    <!-- Row Number -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TrackNumber}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center" />

                                    <!-- Title + Artist -->
                                    <StackPanel Grid.Column="1"
                                                Spacing="2"
                                                VerticalAlignment="Center"
                                                Margin="0,0,16,0">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Artist}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <!-- Album -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Album}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />

                                    <!-- Duration -->
                                    <TextBlock Grid.Column="3"
                                               FontSize="13"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right">
                                        <TextBlock.Text>
                                            <Binding Path="Duration" Converter="{StaticResource TimeSpanConverter}" />
                                        </TextBlock.Text>
                                    </TextBlock>

                                    <!-- Plays -->
                                    <TextBlock Grid.Column="4"
                                               Text="-"
                                               FontSize="13"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />

                                    <!-- Play/Pause Button Panel -->
                                    <Panel Grid.Column="5" Margin="12,0,0,0">
                                        <!-- Play Button (visible when NOT playing this song) -->
                                        <Button Width="34" Height="34" CornerRadius="9999"
                                                Background="{StaticResource BgCardHoverBrush}"
                                                BorderBrush="{StaticResource SongRowBorderBrush}" BorderThickness="1"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).PlaySongCommand}"
                                                CommandParameter="{Binding FilePath}">
                                            <Button.IsVisible>
                                                <MultiBinding Converter="{StaticResource SongIsPlayingConverter}"
                                                              ConverterParameter="invert">
                                                    <Binding Path="FilePath" />
                                                    <Binding
                                                        Path="$parent[ListBox].((vm:MainWindowViewModel)DataContext).CurrentSong.FilePath" />
                                                    <Binding
                                                        Path="$parent[ListBox].((vm:MainWindowViewModel)DataContext).IsPlaying" />
                                                </MultiBinding>
                                            </Button.IsVisible>
                                            <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons" FontSize="14"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>
                                        <!-- Pause Button (visible when playing this song) -->
                                        <Button Width="34" Height="34" CornerRadius="9999"
                                                Background="{StaticResource AccentPurpleBrush}"
                                                BorderThickness="0"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).PauseCommand}">
                                            <Button.IsVisible>
                                                <MultiBinding Converter="{StaticResource SongIsPlayingConverter}">
                                                    <Binding Path="FilePath" />
                                                    <Binding
                                                        Path="$parent[ListBox].((vm:MainWindowViewModel)DataContext).CurrentSong.FilePath" />
                                                    <Binding
                                                        Path="$parent[ListBox].((vm:MainWindowViewModel)DataContext).IsPlaying" />
                                                </MultiBinding>
                                            </Button.IsVisible>
                                            <TextBlock Text="&#xE769;" FontFamily="Segoe Fluent Icons" FontSize="14"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>
                                    </Panel>

                                    <!-- Heart Icon -->
                                    <Button Grid.Column="6"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Cursor="Hand"
                                            Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).ToggleFavoriteCommand}"
                                            CommandParameter="{Binding FilePath}">
                                        <Panel>
                                            <!-- Filled heart when favorite -->
                                            <TextBlock Text="&#xEB52;"
                                                       FontFamily="Segoe Fluent Icons"
                                                       FontSize="16"
                                                       Foreground="{StaticResource AccentPinkBrush}"
                                                       IsVisible="{Binding IsFavorite}" />
                                            <!-- Empty heart when not favorite -->
                                            <TextBlock Text="&#xEB51;"
                                                       FontFamily="Segoe Fluent Icons"
                                                       FontSize="16"
                                                       Foreground="{StaticResource HeartInactiveBrush}"
                                                       IsVisible="{Binding !IsFavorite}" />
                                        </Panel>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.DataTemplates>
                </ListBox>
            </Grid>
        </Grid>

        <!-- Bottom Player Bar -->
        <Border Grid.Row="1"
                Background="{StaticResource PlayerBarBgBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="32,16">
            <Grid ColumnDefinitions="Auto,280,*,280">
                <!-- Album Art -->
                <Button Grid.Column="0"
                        Command="{Binding NavigateToPlayerCommand}"
                        Width="56"
                        Height="56"
                        CornerRadius="8"
                        Background="{StaticResource BgCardBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        Margin="0,0,12,0"
                        Padding="0"
                        Cursor="Hand">
                    <Image Source="{Binding CurrentSong.AlbumArtPath, Converter={StaticResource AlbumArtConverter}}"
                           Stretch="UniformToFill" />
                </Button>

                <!-- Song Info -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="12"
                            VerticalAlignment="Center">
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentSong.Title}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="220" />
                        <TextBlock Text="{Binding CurrentSong.Artist}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="220" />
                    </StackPanel>
                    <Button Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            Command="{Binding ToggleFavoriteCommand}"
                            CommandParameter="{Binding CurrentSong.FilePath}">
                        <Panel>
                            <!-- Filled heart when favorite -->
                            <TextBlock Text="&#xEB52;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="18"
                                       Foreground="{StaticResource AccentPinkBrush}"
                                       IsVisible="{Binding CurrentSong.IsFavorite}" />
                            <!-- Empty heart when not favorite -->
                            <TextBlock Text="&#xEB51;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="18"
                                       Foreground="{StaticResource HeartInactiveBrush}"
                                       IsVisible="{Binding !CurrentSong.IsFavorite}" />
                        </Panel>
                    </Button>
                </StackPanel>

                <!-- Center: Controls and Progress -->
                <StackPanel Grid.Column="2"
                            Spacing="6"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <!-- Control Buttons -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="20"
                                HorizontalAlignment="Center">
                        <!-- Shuffle -->
                        <Button Command="{Binding ShuffleCommand}"
                                Background="Transparent"
                                CornerRadius="50"
                                Padding="8"
                                Cursor="Hand"
                                Foreground="{StaticResource AccentPurpleBrush}">
                            <TextBlock Text="&#xE81B;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="16" />
                        </Button>

                        <!-- Previous -->
                        <Button Command="{Binding PreviousCommand}"
                                Background="Transparent"
                                CornerRadius="50"
                                Padding="8"
                                Cursor="Hand"
                                Foreground="{StaticResource TextPrimaryBrush}">
                            <TextBlock Text="&#xE892;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="22" />
                        </Button>

                        <!-- Play -->
                        <Button Command="{Binding PlayCommand}"
                                IsVisible="{Binding !IsPlaying}"
                                Width="40"
                                Height="40"
                                CornerRadius="50"
                                Cursor="Hand"
                                Background="{StaticResource PlayButtonGradient}"
                                Foreground="{StaticResource TextPrimaryBrush}">
                            <TextBlock Text="&#xE768;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>

                        <!-- Pause -->
                        <Button Command="{Binding PauseCommand}"
                                IsVisible="{Binding IsPlaying}"
                                Width="40"
                                Height="40"
                                CornerRadius="50"
                                Cursor="Hand"
                                Background="{StaticResource PlayButtonGradient}"
                                Foreground="{StaticResource TextPrimaryBrush}">
                            <TextBlock Text="&#xE769;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>

                        <!-- Next -->
                        <Button Command="{Binding NextCommand}"
                                Background="Transparent"
                                CornerRadius="50"
                                Padding="8"
                                Cursor="Hand"
                                Foreground="{StaticResource TextPrimaryBrush}">
                            <TextBlock Text="&#xE893;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="22" />
                        </Button>

                        <!-- Repeat -->
                        <Button Command="{Binding RepeatCommand}"
                                Background="Transparent"
                                CornerRadius="50"
                                Padding="8"
                                Cursor="Hand"
                                Foreground="{StaticResource TextSecondaryBrush}">
                            <TextBlock Text="&#xE8ED;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="16" />
                        </Button>
                    </StackPanel>

                    <!-- Progress Bar -->
                    <views:MusicProgressBar />
                </StackPanel>

                <!-- Right: Queue, Volume, Fullscreen -->
                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            Spacing="16"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <!-- Queue Button -->
                    <Button Command="{Binding ToggleQueuePanelCommand}"
                            Background="Transparent"
                            CornerRadius="50"
                            Padding="8"
                            Cursor="Hand"
                            Foreground="{StaticResource TextMutedBrush}">
                        <TextBlock Text="&#xE8FA;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="16" />
                    </Button>

                    <!-- Volume Control -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Width="120"
                                VerticalAlignment="Center">
                        <!-- Volume unmuted -->
                        <Button Command="{Binding MuteCommand}"
                                Background="Transparent"
                                CornerRadius="50"
                                Padding="4"
                                Cursor="Hand"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                IsVisible="{Binding !IsMuted}">
                            <TextBlock Text="&#xE15D;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="16" />
                        </Button>
                        <!-- Volume muted -->
                        <Button Command="{Binding MuteCommand}"
                                Background="Transparent"
                                CornerRadius="50"
                                Padding="4"
                                Cursor="Hand"
                                Foreground="{StaticResource TextMutedBrush}"
                                IsVisible="{Binding IsMuted}">
                            <TextBlock Text="&#xE198;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="16" />
                        </Button>
                        <Slider Theme="{StaticResource VolumeControlSliderTheme}"
                                Minimum="0"
                                Maximum="100"
                                Value="{Binding Volume}"
                                VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Fullscreen Button -->
                    <Button Background="Transparent"
                            CornerRadius="50"
                            Padding="8"
                            Cursor="Hand"
                            Foreground="{StaticResource TextMutedBrush}">
                        <TextBlock Text="&#xE740;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

