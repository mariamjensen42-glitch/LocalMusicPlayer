<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalMusicPlayer.ViewModels"
             xmlns:models="using:LocalMusicPlayer.Models"
             xmlns:converters="using:LocalMusicPlayer.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="LocalMusicPlayer.Views.PlaylistManagementView"
             x:DataType="vm:PlaylistManagementViewModel">

    <Design.DataContext>
        <vm:PlaylistManagementViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />
        <converters:CountToBoolConverter x:Key="CountToBoolConverter" />
    </UserControl.Resources>

    <Grid ColumnDefinitions="280,*">
        <!-- 左侧：播放列表列表 -->
        <Border Grid.Column="0"
                Background="{StaticResource BgSidebarBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">
                <!-- 头部 -->
                <StackPanel Grid.Row="0" Margin="16,16,16,12">
                    <TextBlock Text="Playlists"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <!-- 创建新播放列表按钮 -->
                    <Button Height="36"
                            Margin="0,12,0,0"
                            Background="{StaticResource AccentPurpleBrush}"
                            CornerRadius="8"
                            Foreground="White"
                            FontSize="13"
                            FontWeight="Medium"
                            Command="{Binding CreatePlaylistCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#xE710;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="New Playlist" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 播放列表列表 -->
                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding UserPlaylists}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:UserPlaylist">
                                <Border Background="{StaticResource BgCardBrush}"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16,12"
                                        Cursor="Hand"
                                        Tapped="PlaylistItem_Tapped">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0"
                                                   Text="&#xE8FA;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="16"
                                                   Foreground="{StaticResource AccentPurpleBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 右侧：播放列表内容 -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <!-- 播放列表标题和操作 -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="24,16">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{Binding SelectedPlaylist.Name}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding PlaylistSongs.Count}"
                                   FontSize="14"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,0,2" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Height="32"
                                Background="{StaticResource PurplePinkGradientBrush}"
                                CornerRadius="8"
                                Foreground="White"
                                FontSize="12"
                                Command="{Binding PlayAllCommand}"
                                IsEnabled="{Binding PlaylistSongs.Count, Converter={StaticResource CountToBoolConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="&#xE768;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Play All" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Height="32"
                                Background="{StaticResource BgCardHoverBrush}"
                                CornerRadius="8"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                FontSize="12"
                                Command="{Binding DeletePlaylistCommand}"
                                IsEnabled="{Binding CanDeletePlaylist}">
                            <TextBlock Text="&#xE74D;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 歌曲列表 -->
            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding PlaylistSongs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Song">
                            <Border Background="Transparent"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="24,12">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                    <!-- 专辑封面 -->
                                    <Border Grid.Column="0"
                                            Width="48"
                                            Height="48"
                                            CornerRadius="8"
                                            Background="{StaticResource BgElement2Brush}">
                                        <Image Source="{Binding AlbumArtPath}"
                                               Stretch="UniformToFill" />
                                    </Border>

                                    <!-- 歌曲信息 -->
                                    <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding Artist}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>

                                    <!-- 专辑名 -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Album}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Width="150"
                                               TextTrimming="CharacterEllipsis" />

                                    <!-- 时长 -->
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Duration, Converter={StaticResource TimeSpanToStringConverter}}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center"
                                               FontFamily="Consolas, monospace"
                                               Margin="16,0" />

                                    <!-- 播放按钮 -->
                                    <Button Grid.Column="4"
                                            Width="32"
                                            Height="32"
                                            Background="{StaticResource BgCardHoverBrush}"
                                            CornerRadius="8"
                                            Command="{Binding $parent[ItemsControl].DataContext.PlaySongCommand}"
                                            CommandParameter="{Binding FilePath}">
                                        <TextBlock Text="&#xE768;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="12"
                                                   Foreground="{StaticResource AccentPurpleBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>