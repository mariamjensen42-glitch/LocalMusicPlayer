<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalMusicPlayer.ViewModels"
             xmlns:services="using:LocalMusicPlayer.Services"
             xmlns:views="using:LocalMusicPlayer.Views"
             xmlns:behaviors="using:LocalMusicPlayer.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="LocalMusicPlayer.Views.PlayerPageView"
             x:DataType="vm:PlayerPageViewModel">

    <Design.DataContext>
        <vm:PlayerPageViewModel />
    </Design.DataContext>

    <Grid Background="{StaticResource BgPrimaryBrush}">
        <Grid RowDefinitions="Auto,*">
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="32,24,32,0">
                <!-- Left: Back Button + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                    <!-- Back Button -->
                    <Button Theme="{StaticResource CircleIconButtonTheme}"
                            Command="{Binding NavigateBackCommand}">
                        <TextBlock Text="&#xE74A;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="16"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <TextBlock Text="{StaticResource String_NowPlaying}"
                               Theme="{StaticResource TitleTextStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Right: Queue + More Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16">
                    <!-- Queue Button -->
                    <Button Theme="{StaticResource CircleIconButtonTheme}"
                            Command="{Binding ToggleQueuePanelCommand}">
                        <TextBlock Text="&#xE8FA;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="18"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <!-- More Button -->
                    <Button Theme="{StaticResource CircleIconButtonTheme}">
                        <TextBlock Text="&#xE712;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="18"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="32,24,32,32">
                <!-- Left: Cover Area + Controls -->
                <Grid Grid.Column="0" RowDefinitions="*,Auto,Auto" HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" Margin="32,0">
                    <!-- Cover -->
                    <Border HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            MaxWidth="480"
                            MaxHeight="480"
                            CornerRadius="24"
                            Background="Transparent"
                            BorderThickness="0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000"
                                              BlurRadius="64"
                                              OffsetX="0"
                                              OffsetY="24"
                                              Opacity="0.6" />
                        </Border.Effect>
                        <Image
                            Source="{Binding CurrentSong.AlbumArtPath, Converter={StaticResource AlbumArtConverter}}"
                            Stretch="Uniform"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>

                    <!-- Progress Section -->
                    <StackPanel Grid.Row="1" Spacing="12" Margin="0,24,0,24">
                        <!-- Progress Bar -->
                        <views:MusicProgressBar />
                    </StackPanel>

                    <!-- Controls Section -->
                    <StackPanel Grid.Row="2" Spacing="24">
                        <!-- Control Buttons -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="32">
                            <!-- Shuffle -->
                            <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                    Command="{Binding ShuffleCommand}">
                                <Panel>
                                    <TextBlock Text="&#xE8B1;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="24"
                                               Foreground="{StaticResource AccentPurpleBrush}"
                                               IsVisible="{Binding IsShuffle}" />
                                    <TextBlock Text="&#xE8B1;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="24"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               IsVisible="{Binding !IsShuffle}" />
                                </Panel>
                            </Button>
                            <!-- Previous -->
                            <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                    Command="{Binding PreviousCommand}">
                                <TextBlock Text="&#xE892;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="32"
                                           Foreground="White" />
                            </Button>
                            <!-- Play/Pause -->
                            <Button Theme="{StaticResource CircleIconButtonLargeTheme}"
                                    Command="{Binding PlayCommand}"
                                    IsVisible="{Binding !IsPlaying}">
                                <TextBlock Text="&#xE768;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="32"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                            <Button Theme="{StaticResource CircleIconButtonLargeTheme}"
                                    Command="{Binding PauseCommand}"
                                    IsVisible="{Binding IsPlaying}">
                                <TextBlock Text="&#xE769;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="32"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                            <!-- Next -->
                            <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                    Command="{Binding NextCommand}">
                                <TextBlock Text="&#xE893;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="32"
                                           Foreground="White" />
                            </Button>
                            <!-- Repeat -->
                            <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                    Command="{Binding RepeatCommand}">
                                <Panel>
                                    <TextBlock Text="&#xE8ED;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="24"
                                               Foreground="{StaticResource AccentPurpleBrush}"
                                               IsVisible="{Binding IsRepeat}" />
                                    <TextBlock Text="&#xE8ED;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="24"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               IsVisible="{Binding !IsRepeat}" />
                                </Panel>
                            </Button>
                        </StackPanel>

                        <!-- Bottom Actions -->
                        <Grid ColumnDefinitions="*,*" Margin="24,0,0,0">
                            <!-- Left: Like + Share -->
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        Spacing="20">
                                <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                        Command="{Binding ToggleFavoriteCommand}">
                                    <Panel>
                                        <TextBlock Text="&#xEB52;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="24"
                                                   Foreground="{StaticResource AccentPinkBrush}"
                                                   IsVisible="{Binding CurrentSong.IsFavorite}" />
                                        <TextBlock Text="&#xEB51;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="24"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   IsVisible="{Binding !CurrentSong.IsFavorite}" />
                                    </Panel>
                                </Button>
                                <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                        Foreground="{StaticResource TextMutedBrush}">
                                    <TextBlock Text="&#xE72D;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="20" />
                                </Button>
                            </StackPanel>
                            <!-- Right: Cast + Volume -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="20"
                                        HorizontalAlignment="Right">
                                <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                        Foreground="{StaticResource TextMutedBrush}">
                                    <TextBlock Text="&#xE8C9;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="20" />
                                </Button>
                                <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                        Command="{Binding ToggleMuteCommand}"
                                        Foreground="{StaticResource TextMutedBrush}">
                                    <Panel>
                                        <TextBlock Text="&#xE15D;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="20"
                                                   IsVisible="{Binding !IsMuted}" />
                                        <TextBlock Text="&#xE198;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="20"
                                                   IsVisible="{Binding IsMuted}" />
                                    </Panel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Right: Lyrics Area -->
                <Grid Grid.Column="1" Margin="32,0,0,0">
                    <ScrollViewer x:Name="LyricsScrollViewer"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  IsVisible="{Binding HasLyrics}">
                        <ItemsControl ItemsSource="{Binding Lyrics}"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,300,0,300">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="services:LyricLine">
                                    <StackPanel Spacing="6"
                                                Margin="0,20,0,20"
                                                HorizontalAlignment="Center">
                                        <!-- Original Lyric -->
                                        <TextBlock Text="{Binding Text}"
                                                   FontSize="28"
                                                   FontWeight="{Binding IsActive, Converter={StaticResource BoolToFontWeightConverter}}"
                                                   FontFamily="Inter"
                                                   Foreground="{Binding IsActive, Converter={StaticResource BoolToLyricColorConverter}}"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap" />
                                        <!-- Translation -->
                                        <TextBlock
                                            IsVisible="{Binding Translation, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                            Text="{Binding Translation}"
                                            FontSize="16"
                                            FontFamily="Inter"
                                            Foreground="{StaticResource TextMutedBrush}"
                                            TextAlignment="Center"
                                            TextWrapping="Wrap"
                                            Opacity="0.9" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- No Lyrics Message -->
                    <TextBlock IsVisible="{Binding !HasLyrics}"
                               Text="{StaticResource String_NoLyrics}"
                               FontSize="16"
                               FontFamily="Inter"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

