<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalMusicPlayer.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="1000"
             x:Class="LocalMusicPlayer.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <Design.DataContext>
        <vm:SettingsViewModel />
    </Design.DataContext>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" Margin="32,0,32,32">
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{StaticResource String_Settings}"
                           Grid.Column="0"
                           FontSize="32"
                           FontWeight="Bold"
                           FontFamily="{StaticResource FontFamilyPrimary}"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="{StaticResource String_CustomizeExperience}"
                           Grid.Column="1"
                           FontSize="14"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Bottom"
                           Margin="16,0,0,4" />
            </Grid>

            <Border Theme="{StaticResource CardTheme}">
                <StackPanel Spacing="24">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource AccentPurpleBrush}">
                            <TextBlock Text="&#xE8B7;"
                                       FontFamily="Segoe Fluent Icons"
                                       Foreground="White"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="{StaticResource String_LocalMusicLibrary}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{StaticResource String_ManageMusicFiles}"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource BgElement2Brush}" />

                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{StaticResource String_MusicFolders}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       LetterSpacing="4"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Theme="{StaticResource AccentButtonTheme}"
                                    Height="28"
                                    FontSize="11"
                                    Command="{Binding AddFolderCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="&#xE710;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{StaticResource String_Add}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border Theme="{StaticResource InputBorderTheme}"
                                MinHeight="80"
                                MaxHeight="200">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ScanFolders}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Border Background="Transparent"
                                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="12,10">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center" />
                                                    <Button Grid.Column="1"
                                                            Theme="{StaticResource IconButtonTheme}"
                                                            x:DataType="vm:SettingsViewModel"
                                                            Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).RemoveFolderCommand}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="&#xE74D;"
                                                                   FontFamily="Segoe Fluent Icons"
                                                                   FontSize="14"
                                                                   Foreground="{StaticResource TextMutedBrush}" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource BgElement2Brush}" />

                    <StackPanel Spacing="12">
                        <TextBlock Text="{StaticResource String_ScanOptions}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   LetterSpacing="4" />

                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                            <CheckBox Grid.Row="0" Grid.Column="0"
                                      Content="{StaticResource String_ScanSubfolders}"
                                      IsChecked="{Binding IncludeSubfolders}"
                                      Foreground="{StaticResource TextPrimaryBrush}" />
                            <CheckBox Grid.Row="1" Grid.Column="0"
                                      Content="{StaticResource String_DownloadAlbumArt}"
                                      IsChecked="{Binding DownloadAlbumArtwork}"
                                      Foreground="{StaticResource TextPrimaryBrush}" />
                            <CheckBox Grid.Row="2" Grid.Column="0"
                                      Content="{StaticResource String_AutoMetadata}"
                                      IsChecked="{Binding AutoDetectMetadata}"
                                      Foreground="{StaticResource TextPrimaryBrush}" />
                        </Grid>
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource BgElement2Brush}" />

                    <Button Theme="{StaticResource AccentButtonTheme}"
                            Height="40"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ScanAllCommand}"
                            IsEnabled="{Binding !IsScanning}">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="16"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{StaticResource String_RescanLibrary}"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <StackPanel Orientation="Horizontal" Spacing="24">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding SongCount}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{StaticResource String_Songs}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding AlbumCount}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{StaticResource String_Albums}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding TotalSize}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{StaticResource String_Size}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding LastScanTime}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{StaticResource String_LastScan}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Theme="{StaticResource CardTheme}">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource AccentPurpleBrush}">
                            <TextBlock Text="&#xE8D7;"
                                       FontFamily="Segoe Fluent Icons"
                                       Foreground="White"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="{StaticResource String_Playback}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{StaticResource String_PlaybackSettings}"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource BgElement2Brush}" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="{StaticResource String_AudioQuality}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   LetterSpacing="4" />

                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                            <RadioButton Grid.Row="0" Grid.Column="0"
                                         Content="{StaticResource String_Standard}"
                                         IsChecked="{Binding AudioQuality, Converter={StaticResource EnumBooleanConverter}, ConverterParameter=Standard}"
                                         HorizontalAlignment="Center" />
                            <RadioButton Grid.Row="0" Grid.Column="1"
                                         Content="{StaticResource String_High}"
                                         IsChecked="{Binding AudioQuality, Converter={StaticResource EnumBooleanConverter}, ConverterParameter=High}"
                                         HorizontalAlignment="Center" />
                            <RadioButton Grid.Row="0" Grid.Column="2"
                                         Content="{StaticResource String_Lossless}"
                                         IsChecked="{Binding AudioQuality, Converter={StaticResource EnumBooleanConverter}, ConverterParameter=Lossless}"
                                         HorizontalAlignment="Center" />
                        </Grid>
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource BgElement2Brush}" />

                    <StackPanel Spacing="12">
                        <TextBlock Text="{DynamicResource String_PlaybackEffects}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   LetterSpacing="4" />

                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{DynamicResource String_Crossfade}"
                                       FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                          IsChecked="{Binding CrossfadeEnabled}" />

                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                        Spacing="8"
                                        IsVisible="{Binding CrossfadeEnabled}">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="1s"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center" />
                                    <Slider Grid.Column="1"
                                            Minimum="1"
                                            Maximum="10"
                                            Value="{Binding CrossfadeDurationSeconds}"
                                            Margin="8,0" />
                                    <TextBlock Grid.Column="2"
                                               Text="10s"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <TextBlock Text="{Binding CrossfadeDurationSeconds, StringFormat='{}{0} 秒'}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="{DynamicResource String_VolumeNormalization}"
                                       FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,8,0,0" />
                            <ToggleSwitch Grid.Row="2" Grid.Column="1"
                                          IsChecked="{Binding ReplayGainEnabled}"
                                          Margin="0,8,0,0" />
                        </Grid>
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource BgElement2Brush}" />

                    <StackPanel Spacing="12">
                        <TextBlock Text="{DynamicResource String_PlaybackSpeed}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   LetterSpacing="4" />

                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="0.5x"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center" />
                            <Slider Grid.Column="1"
                                    Minimum="0.5"
                                    Maximum="2.0"
                                    Value="{Binding PlaybackRate}"
                                    Margin="8,0" />
                            <TextBlock Grid.Column="2"
                                       Text="2.0x"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Text="{Binding PlaybackRate, StringFormat='{}{0:0.##}x'}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Theme="{StaticResource CardTheme}">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource AccentPurpleBrush}">
                            <TextBlock Text="&#xE790;"
                                       FontFamily="Segoe Fluent Icons"
                                       Foreground="White"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="{StaticResource String_Appearance}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{StaticResource String_AppearanceSettings}"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource BgElement2Brush}" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="{StaticResource String_Theme}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   LetterSpacing="4" />

                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                            <RadioButton Grid.Row="0" Grid.Column="0"
                                         Content="{StaticResource String_Dark}"
                                         IsChecked="{Binding ThemeMode, Converter={StaticResource EnumBooleanConverter}, ConverterParameter=Dark}"
                                         HorizontalAlignment="Center" />
                            <RadioButton Grid.Row="0" Grid.Column="1"
                                         Content="{StaticResource String_Light}"
                                         IsChecked="{Binding ThemeMode, Converter={StaticResource EnumBooleanConverter}, ConverterParameter=Light}"
                                         HorizontalAlignment="Center" />
                            <RadioButton Grid.Row="0" Grid.Column="2"
                                         Content="{StaticResource String_Auto}"
                                         IsChecked="{Binding ThemeMode, Converter={StaticResource EnumBooleanConverter}, ConverterParameter=Auto}"
                                         HorizontalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Theme="{StaticResource CardTheme}">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource AccentPurpleBrush}">
                            <TextBlock Text="&#xE946;"
                                       FontFamily="Segoe Fluent Icons"
                                       Foreground="White"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="{StaticResource String_About}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{StaticResource String_AppInfo}"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource BgElement2Brush}" />

                    <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{StaticResource String_Version}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="2.0.1"
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" />

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{StaticResource String_Build}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,8,0,0" />
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="2024.04.05"
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,8,0,0" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{StaticResource String_Developer}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,8,0,0" />
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="LocalMusic Team"
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,8,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

