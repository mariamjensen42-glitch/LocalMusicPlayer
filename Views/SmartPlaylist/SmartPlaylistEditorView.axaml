<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LocalMusicPlayer.ViewModels"
        xmlns:models="using:LocalMusicPlayer.Models"
        x:Class="LocalMusicPlayer.Views.SmartPlaylist.SmartPlaylistEditorView"
        x:DataType="vm:SmartPlaylistEditorViewModel"
        Title="{Binding PageTitle}"
        Width="480"
        Height="520"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#1E1E2E"
        BorderBrush="#3B3B5C"
        BorderThickness="1">

    <Grid RowDefinitions="Auto,*,Auto" Margin="24">

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,24">
            <TextBlock Text="{Binding PageTitle}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#E0E0E0" />
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20">

                <!-- Name -->
                <StackPanel Spacing="8">
                    <TextBlock Text="播放列表名称"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#808090"
                               LetterSpacing="2" />
                    <TextBox Text="{Binding PlaylistName}"
                             Watermark="输入名称..."
                             FontSize="14"
                             Height="40" />
                </StackPanel>

                <!-- Rule -->
                <StackPanel Spacing="8">
                    <TextBlock Text="规则"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#808090"
                               LetterSpacing="2" />
                    <ComboBox ItemsSource="{Binding AvailableRules}"
                              SelectedItem="{Binding SelectedRule}"
                              FontSize="14"
                              Height="40">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:SmartPlaylistRule">
                                <TextBlock Text="{Binding}" FontSize="14" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Limit -->
                <StackPanel Spacing="8">
                    <TextBlock Text="歌曲数量限制"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#808090"
                               LetterSpacing="2" />
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="1"
                                   FontSize="12"
                                   Foreground="#808090"
                                   VerticalAlignment="Center" />
                        <Slider Grid.Column="1"
                                Minimum="1"
                                Maximum="200"
                                Value="{Binding Limit}"
                                Margin="8,0" />
                        <TextBlock Grid.Column="2"
                                   Text="200"
                                   FontSize="12"
                                   Foreground="#808090"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="{Binding Limit, StringFormat='{}{0} 首歌曲'}"
                               FontSize="12"
                               Foreground="#B0B0B0"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Date Range -->
                <StackPanel Spacing="8">
                    <TextBlock Text="日期范围（可选）"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#808090"
                               LetterSpacing="2" />
                    <Grid ColumnDefinitions="*,8,*">
                        <DatePicker Grid.Column="0"
                                    SelectedDate="{Binding FromDate}"
                                    Height="40" />
                        <TextBlock Grid.Column="1"
                                   Text="—"
                                   FontSize="14"
                                   Foreground="#808090"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <DatePicker Grid.Column="2"
                                    SelectedDate="{Binding ToDate}"
                                    Height="40" />
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="12"
                    Margin="0,24,0,0">

            <Button Content="取消"
                    Command="{Binding CancelCommand}"
                    MinWidth="90"
                    Height="36"
                    FontSize="14">
                <Button.Styles>
                    <Style Selector="Button">
                        <Setter Property="Background" Value="#2A2A3E" />
                        <Setter Property="Foreground" Value="#E0E0E0" />
                    </Style>
                </Button.Styles>
            </Button>

            <Button Content="保存"
                    Command="{Binding SaveCommand}"
                    MinWidth="90"
                    Height="36"
                    FontSize="14"
                    Background="#B088F9"
                    Foreground="White">
            </Button>

        </StackPanel>
    </Grid>
</Window>
