<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LocalMusicPlayer.ViewModels"
        xmlns:converters="using:LocalMusicPlayer.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="900"
        MinWidth="1100" MinHeight="700"
        x:Class="LocalMusicPlayer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="LocalMusicPlayer"
        Background="{StaticResource BgPrimaryBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <converters:BoolToWidthConverter x:Key="BoolToWidthConverter" />
        <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
    </Window.Resources>

    <Grid ColumnDefinitions="Auto,*">
        <Border Grid.Column="0"
                Background="{StaticResource BgSidebarBrush}"
                ClipToBounds="True"
                Width="{Binding SidebarWidth}">
            <Grid RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0"
                        Width="40"
                        Height="40"
                        Background="{StaticResource AccentPurpleBrush}"
                        CornerRadius="10"
                        HorizontalAlignment="Center"
                        Margin="0,16,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#A855F7" BlurRadius="12" OffsetX="0" OffsetY="4" Opacity="0.3" />
                    </Border.Effect>
                    <TextBlock Text="&#xE80A;"
                               FontFamily="Segoe Fluent Icons"
                               Foreground="White"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Top"
                            Spacing="8"
                            Margin="16,24,16,0">
                    <Button Theme="{StaticResource SidebarIconButtonTheme}"
                            Command="{Binding NavigateToLibraryCommand}"
                            HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8FA;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="18"
                                   Foreground="{Binding IsLibrarySelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter=accent}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <Button Theme="{StaticResource SidebarIconButtonTheme}"
                            Command="{Binding NavigateToCategoryCommand}"
                            HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8FD;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="18"
                                   Foreground="{Binding IsCategorySelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter=accent}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <Button Theme="{StaticResource SidebarIconButtonTheme}"
                            Command="{Binding NavigateToStatisticsCommand}"
                            HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8B7;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="18"
                                   Foreground="{Binding IsStatisticsSelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter=accent}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <Button Theme="{StaticResource SidebarIconButtonTheme}"
                            Command="{Binding NavigateToSettingsCommand}"
                            HorizontalAlignment="Center">
                        <TextBlock Text="&#xE713;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="18"
                                   Foreground="{Binding IsSettingsSelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter=accent}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </StackPanel>

                <Button Grid.Row="2"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Center"
                        Background="{StaticResource AccentPurpleTranslucentBrush}"
                        BorderBrush="{StaticResource AccentPurpleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="0"
                        Cursor="Hand"
                        Margin="0,0,0,24">
                    <Button.Effect>
                        <DropShadowEffect Color="#A855F7" BlurRadius="8" OffsetX="0" OffsetY="2" Opacity="0.2" />
                    </Button.Effect>
                    <TextBlock Text="&#xE8F1;"
                               FontFamily="Segoe Fluent Icons"
                               FontSize="18"
                               Foreground="{StaticResource AccentPurpleBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <Border Grid.Row="0"
                    x:Name="TitleBar"
                    Background="Transparent"
                    Height="48"
                    BorderThickness="0">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <Border Grid.Column="0" Background="Transparent" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Spacing="8"
                                Margin="0,0,16,0">
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Width="280"
                                Height="36">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0"
                                           Text="&#xE71E;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="14"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="12,0,8,0" />
                                <TextBox Grid.Column="1"
                                         x:Name="SearchTextBox"
                                         Watermark="{StaticResource String_Search}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         VerticalAlignment="Center"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         CaretBrush="{StaticResource TextPrimaryBrush}" />
                            </Grid>
                        </Border>

                        <Button Theme="{StaticResource ToolbarButtonTheme}">
                            <TextBlock Text="&#xE71C;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="14"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>

                        <Button Theme="{StaticResource ToolbarButtonTheme}">
                            <TextBlock Text="&#xE80A;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="14"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0">
                        <Button x:Name="MinimizeButton"
                                Width="40"
                                Height="40"
                                Theme="{StaticResource TitleBarButtonTheme}"
                                Click="MinimizeButton_Click">
                            <TextBlock Text="&#xE921;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>

                        <Button x:Name="MaximizeButton"
                                Width="40"
                                Height="40"
                                Theme="{StaticResource TitleBarButtonTheme}"
                                Click="MaximizeButton_Click">
                            <Panel>
                                <TextBlock Text="&#xE922;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           x:Name="MaximizeIcon" />
                                <TextBlock Text="&#xE923;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           x:Name="RestoreIcon"
                                           IsVisible="False" />
                            </Panel>
                        </Button>

                        <Button x:Name="CloseButton"
                                Width="40"
                                Height="40"
                                Theme="{StaticResource TitleBarCloseButtonTheme}"
                                Click="CloseButton_Click">
                            <TextBlock Text="&#xE8BB;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <ContentControl Content="{Binding CurrentPage}" />

                <Border HorizontalAlignment="Right"
                        Background="{StaticResource BgSidebarBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1,0,0,0"
                        Width="320"
                        ZIndex="100"
                        ClipToBounds="True"
                        IsVisible="{Binding IsQueuePanelOpen}">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                        </Transitions>
                    </Border.Transitions>
                    <ContentControl Content="{Binding QueueViewModel}" />
                </Border>
            </Grid>
        </Grid>
    </Grid>

</Window>

