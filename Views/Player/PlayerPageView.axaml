<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalMusicPlayer.ViewModels"
             xmlns:services="using:LocalMusicPlayer.Services"
             xmlns:player="using:LocalMusicPlayer.Views.Player"
             xmlns:behaviors="using:LocalMusicPlayer.Behaviors"
             xmlns:converters="using:LocalMusicPlayer.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="LocalMusicPlayer.Views.Player.PlayerPageView"
             x:DataType="vm:PlayerPageViewModel">

    <Design.DataContext>
        <vm:PlayerPageViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <converters:StringToBrushConverter x:Key="StringToBrushConverter" />
    </UserControl.Resources>

    <Grid Background="{Binding GradientBackground, Converter={StaticResource StringToBrushConverter}}"
          Margin="0,-48,0,0">
        <Grid RowDefinitions="Auto,*" Margin="0,48,0,0">
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="32,24,32,0">
                <!-- 窗口拖拽区域 -->
                <Border Grid.ColumnSpan="3"
                        Background="Transparent"
                        IsHitTestVisible="True"
                        ZIndex="-1">
                    <i:Interaction.Behaviors>
                        <behaviors:WindowDragBehavior />
                    </i:Interaction.Behaviors>
                </Border>

                <!-- Left: Back Button + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                    <!-- Back Button -->
                    <Button Theme="{StaticResource CircleIconButtonTheme}"
                            Command="{Binding NavigateBackCommand}">
                        <TextBlock Text="&#xE74A;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="16"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <TextBlock Text="{StaticResource String_NowPlaying}"
                               Theme="{StaticResource TitleTextStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Right: Queue + FullScreen + More Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16">
                    <!-- Queue Button -->
                    <Button Theme="{StaticResource CircleIconButtonTheme}"
                            Command="{Binding ToggleQueuePanelCommand}">
                        <TextBlock Text="&#xE8FA;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="18"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <!-- FullScreen Button -->
                    <Button Theme="{StaticResource CircleIconButtonTheme}"
                            Command="{Binding ToggleFullScreenCommand}"
                            ToolTip.Tip="{DynamicResource String_Fullscreen}">
                        <TextBlock Text="&#xE73E;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="16"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <!-- More Button -->
                    <Button Theme="{StaticResource CircleIconButtonTheme}">
                        <TextBlock Text="&#xE712;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="18"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="32,24,32,32">
                <!-- Left: Cover Area + Controls -->
                <Grid Grid.Column="0" RowDefinitions="*,Auto,Auto" HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" Margin="32,0">
                    <!-- Cover -->
                    <Border HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            MaxWidth="480"
                            MaxHeight="480"
                            CornerRadius="24"
                            Background="Transparent"
                            BorderThickness="0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000"
                                              BlurRadius="64"
                                              OffsetX="0"
                                              OffsetY="24"
                                              Opacity="0.6" />
                        </Border.Effect>
                        <Image
                            Source="{Binding CurrentSong.AlbumArtPath, Converter={StaticResource AlbumArtConverter}}"
                            Stretch="Uniform"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>

                    <!-- Progress Section -->
                    <StackPanel Grid.Row="1" Spacing="12" Margin="0,24,0,24">
                        <!-- Progress Bar -->
                        <player:MusicProgressBar />
                    </StackPanel>

                    <!-- Controls Section -->
                    <StackPanel Grid.Row="2" Spacing="24">
                        <!-- Control Buttons -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="32">
                            <!-- Shuffle -->
                            <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                    Command="{Binding ShuffleCommand}">
                                <Panel>
                                    <TextBlock Text="&#xE8B1;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="24"
                                               Foreground="{StaticResource AccentPurpleBrush}"
                                               IsVisible="{Binding IsShuffle}" />
                                    <TextBlock Text="&#xE8B1;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="24"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               IsVisible="{Binding !IsShuffle}" />
                                </Panel>
                            </Button>
                            <!-- Previous -->
                            <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                    Command="{Binding PreviousCommand}">
                                <TextBlock Text="&#xE892;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="32"
                                           Foreground="White" />
                            </Button>
                            <!-- Play/Pause -->
                            <Button Theme="{StaticResource CircleIconButtonLargeTheme}"
                                    Command="{Binding PlayCommand}"
                                    IsVisible="{Binding !IsPlaying}">
                                <TextBlock Text="&#xE768;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="32"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                            <Button Theme="{StaticResource CircleIconButtonLargeTheme}"
                                    Command="{Binding PauseCommand}"
                                    IsVisible="{Binding IsPlaying}">
                                <TextBlock Text="&#xE769;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="32"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                            <!-- Next -->
                            <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                    Command="{Binding NextCommand}">
                                <TextBlock Text="&#xE893;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="32"
                                           Foreground="White" />
                            </Button>
                            <!-- Repeat -->
                            <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                    Command="{Binding RepeatCommand}">
                                <Grid>
                                    <Panel>
                                        <TextBlock Text="&#xE8ED;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="24"
                                                   Foreground="{StaticResource AccentPurpleBrush}"
                                                   IsVisible="{Binding IsRepeat}" />
                                        <TextBlock Text="&#xE8ED;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="24"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   IsVisible="{Binding !IsRepeat}" />
                                    </Panel>
                                    <TextBlock Text="1"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentPurpleBrush}"
                                               IsVisible="{Binding IsSingleLoop}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,2,2" />
                                </Grid>
                            </Button>
                        </StackPanel>

                        <!-- Bottom Actions -->
                        <Grid ColumnDefinitions="*,*" Margin="24,0,0,0">
                            <!-- Left: Like + Share -->
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        Spacing="20">
                                <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                        Command="{Binding ToggleFavoriteCommand}">
                                    <Panel>
                                        <TextBlock Text="&#xEB52;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="24"
                                                   Foreground="{StaticResource AccentPinkBrush}"
                                                   IsVisible="{Binding CurrentSong.IsFavorite}" />
                                        <TextBlock Text="&#xEB51;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="24"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   IsVisible="{Binding !CurrentSong.IsFavorite}" />
                                    </Panel>
                                </Button>
                                <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                        Foreground="{StaticResource TextMutedBrush}">
                                    <TextBlock Text="&#xE72D;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="20" />
                                </Button>
                            </StackPanel>
                            <!-- Right: Speed + Volume -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="20"
                                        HorizontalAlignment="Right">
                                <Popup HorizontalAlignment="Left"
                                       IsLightDismissEnabled="True"
                                       x:Name="SpeedPopup">
                                    <Border Background="{StaticResource BgCardBrush}"
                                            CornerRadius="12"
                                            Padding="8"
                                            BoxShadow="0 8 32 0 #00000060">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{DynamicResource String_PlaybackSpeed}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Margin="8,4,8,8"
                                                       HorizontalAlignment="Center" />
                                            <ItemsControl ItemsSource="{Binding AvailablePlaybackRates}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding StringFormat='{}{0}x'}"
                                                                Command="{Binding $parent[UserControl].((vm:PlayerPageViewModel)DataContext).ChangePlaybackRateCommand}"
                                                                CommandParameter="{Binding}"
                                                                HorizontalAlignment="Stretch"
                                                                HorizontalContentAlignment="Center"
                                                                Padding="16,8"
                                                                CornerRadius="8"
                                                                Background="Transparent"
                                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                                FontSize="14" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                                <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Click="OnSpeedButtonClick">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="&#xEC57;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="18"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding PlaybackRate, StringFormat='{}{0:0.##}x'}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                        Command="{Binding ToggleMuteCommand}"
                                        Foreground="{StaticResource TextMutedBrush}">
                                    <Panel>
                                        <TextBlock Text="&#xE15D;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="20"
                                                   IsVisible="{Binding !IsMuted}" />
                                        <TextBlock Text="&#xE198;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="20"
                                                   IsVisible="{Binding IsMuted}" />
                                    </Panel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Right: Lyrics Area -->
                <Grid Grid.Column="1" Margin="32,0,0,0">
                    <Grid RowDefinitions="Auto,*">
                        <!-- Lyrics Settings Bar -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal"
                                    Spacing="12" HorizontalAlignment="Right"
                                    Margin="0,0,0,16">
                            <!-- 测试按钮 -->
                            <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                    Command="{Binding ToggleTranslationCommand}"
                                    ToolTip.Tip="测试按钮">
                                <TextBlock Text="T"
                                           FontSize="16" />
                            </Button>
                            <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                    Command="{Binding SearchOnlineLyricsCommand}"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    IsVisible="{Binding !IsSearchingLyrics}"
                                    ToolTip.Tip="搜索歌词">
                                <TextBlock Text="&#xE721;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="16" />
                            </Button>
                            <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                    Foreground="{StaticResource AccentPurpleBrush}"
                                    IsVisible="{Binding IsSearchingLyrics}"
                                    ToolTip.Tip="搜索中...">
                                <TextBlock Text="&#xE895;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="16" />
                            </Button>
                            <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                    Command="{Binding ToggleTranslationCommand}"
                                    Foreground="{StaticResource TextMutedBrush}">
                                <Panel>
                                    <TextBlock Text="&#xE8BD;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="16"
                                               Foreground="{StaticResource AccentPurpleBrush}"
                                               IsVisible="{Binding ShowTranslation}" />
                                    <TextBlock Text="&#xE8BD;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="16"
                                               IsVisible="{Binding !ShowTranslation}" />
                                </Panel>
                            </Button>
                            <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                    Command="{Binding DecreaseLyricFontSizeCommand}"
                                    Foreground="{StaticResource TextMutedBrush}">
                                <TextBlock Text="&#xE8D7;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="16" />
                            </Button>
                            <TextBlock Text="{Binding LyricFontSize, StringFormat='{}{0:0}'}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Width="24"
                                       TextAlignment="Center" />
                            <Button Theme="{StaticResource TransparentIconButtonTheme}"
                                    Command="{Binding IncreaseLyricFontSizeCommand}"
                                    Foreground="{StaticResource TextMutedBrush}">
                                <TextBlock Text="&#xE8D8;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="16" />
                            </Button>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" x:Name="LyricsScrollViewer"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled"
                                      IsVisible="{Binding HasLyrics}">
                            <ItemsControl ItemsSource="{Binding Lyrics}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,300,0,300">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="services:LyricLine">
                                        <StackPanel Spacing="6"
                                                    Margin="0,0,0,0"
                                                    HorizontalAlignment="Center">
                                            <Border
                                                Height="{Binding $parent[UserControl].((vm:PlayerPageViewModel)DataContext).LyricLineSpacing}" />
                                            <!-- Original Lyric -->
                                            <TextBlock Text="{Binding Text}"
                                                       FontSize="{Binding $parent[UserControl].((vm:PlayerPageViewModel)DataContext).LyricFontSize}"
                                                       FontWeight="{Binding IsActive, Converter={StaticResource BoolToFontWeightConverter}}"
                                                       FontFamily="{StaticResource FontFamilyPrimary}"
                                                       Foreground="{Binding IsActive, Converter={StaticResource BoolToLyricColorConverter}}"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                            <!-- Translation -->
                                            <TextBlock
                                                IsVisible="{Binding $parent[UserControl].((vm:PlayerPageViewModel)DataContext).ShowTranslation, Mode=OneWay}"
                                                Text="{Binding Translation}"
                                                FontSize="{Binding $parent[UserControl].((vm:PlayerPageViewModel)DataContext).LyricFontSize, Converter={StaticResource LyricTranslationFontSizeConverter}}"
                                                FontFamily="{StaticResource FontFamilyPrimary}"
                                                Foreground="{StaticResource TextMutedBrush}"
                                                TextAlignment="Center"
                                                TextWrapping="Wrap"
                                                Opacity="0.9" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <!-- No Lyrics Message -->
                    <TextBlock IsVisible="{Binding !HasLyrics}"
                               Text="{StaticResource String_NoLyrics}"
                               FontSize="16"
                               FontFamily="{StaticResource FontFamilyPrimary}"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />

                    <!-- Lyric Search Status -->
                    <TextBlock IsVisible="{Binding LyricSearchStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Text="{Binding LyricSearchStatus}"
                               FontSize="14"
                               FontFamily="{StaticResource FontFamilyPrimary}"
                               Foreground="{StaticResource AccentPurpleBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,20" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

