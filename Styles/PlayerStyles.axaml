<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 音乐进度条样式 -->
    <ControlTheme x:Key="MusicProgressSliderTheme" TargetType="Slider">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Height="20" VerticalAlignment="Center" Background="Transparent">
                    <Grid VerticalAlignment="Center">
                        <Border Name="TrackBackground"
                                Background="{StaticResource SliderTrackOverlayBrush}"
                                CornerRadius="3"
                                Height="5"
                                VerticalAlignment="Center" />
                        <Track Name="PART_Track"
                               VerticalAlignment="Center"
                               IsDirectionReversed="False"
                               Orientation="Horizontal"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{TemplateBinding Value, Mode=TwoWay}">
                            <Track.DecreaseButton>
                                <RepeatButton Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border CornerRadius="3"
                                                    Height="5"
                                                    VerticalAlignment="Center"
                                                    Background="{StaticResource PurplePinkHorizontalGradientBrush}" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseButton>
                            <Track.IncreaseButton>
                                <RepeatButton Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border Background="Transparent"
                                                    Height="5"
                                                    VerticalAlignment="Center" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseButton>
                            <Track.Thumb>
                                <Thumb Width="12" Height="12">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Width="12" Height="12"
                                                    CornerRadius="6"
                                                    Background="White" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <!-- 音量控制滑块样式 -->
    <ControlTheme x:Key="VolumeControlSliderTheme" TargetType="Slider">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Height="16" VerticalAlignment="Center" Background="Transparent">
                    <Grid VerticalAlignment="Center">
                        <Border Name="TrackBackground"
                                Background="{StaticResource SliderTrackOverlayBrush}"
                                CornerRadius="3"
                                Height="5"
                                VerticalAlignment="Center" />
                        <Track Name="PART_Track"
                               VerticalAlignment="Center"
                               IsDirectionReversed="False"
                               Orientation="Horizontal"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{TemplateBinding Value, Mode=TwoWay}">
                            <Track.DecreaseButton>
                                <RepeatButton Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border CornerRadius="3"
                                                    Height="5"
                                                    VerticalAlignment="Center"
                                                    Background="{StaticResource AccentPurpleBrush}" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseButton>
                            <Track.IncreaseButton>
                                <RepeatButton Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border Background="Transparent"
                                                    Height="5"
                                                    VerticalAlignment="Center" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseButton>
                            <Track.Thumb>
                                <Thumb Width="10" Height="10">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Width="10" Height="10"
                                                    CornerRadius="5"
                                                    Background="White" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <!-- 紧凑进度条样式（隐藏Thumb） -->
    <ControlTheme x:Key="CompactProgressSliderTheme" TargetType="Slider">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Height="20" VerticalAlignment="Center" Background="Transparent">
                    <Grid VerticalAlignment="Center">
                        <Border Name="TrackBackground"
                                Background="{StaticResource SliderTrackOverlayBrush}"
                                CornerRadius="4"
                                Height="8"
                                VerticalAlignment="Center" />
                        <Track Name="PART_Track"
                               VerticalAlignment="Center"
                               IsDirectionReversed="False"
                               Orientation="Horizontal"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{TemplateBinding Value, Mode=TwoWay}">
                            <Track.DecreaseButton>
                                <RepeatButton Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border CornerRadius="4"
                                                    Height="8"
                                                    VerticalAlignment="Center"
                                                    Background="{StaticResource PurplePinkHorizontalGradientBrush}" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseButton>
                            <Track.IncreaseButton>
                                <RepeatButton Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border Background="Transparent"
                                                    Height="8"
                                                    VerticalAlignment="Center" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseButton>
                            <Track.Thumb>
                                <Thumb Width="12" Height="12" Opacity="0">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Width="12" Height="12"
                                                    CornerRadius="6"
                                                    Background="Transparent" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <!-- 播放器图标按钮样式 -->
    <ControlTheme x:Key="PlayerIconButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="CornerRadius" Value="50" />
    </ControlTheme>

    <!-- 播放器圆形按钮样式（渐变背景） -->
    <ControlTheme x:Key="PlayerCircleButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PurplePinkVerticalGradientBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="CornerRadius" Value="50" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
    </ControlTheme>

    <!-- 歌曲列表行按钮样式 -->
    <ControlTheme x:Key="SongRowButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgCardHoverBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SongRowBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="CornerRadius" Value="9999" />
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </ControlTheme>

    <!-- 歌曲列表项样式 -->
    <ControlTheme x:Key="SongListItemTheme" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="^:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </ControlTheme>

</ResourceDictionary>