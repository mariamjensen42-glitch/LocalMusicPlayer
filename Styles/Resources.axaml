<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Backgrounds ─────────────────────────────────── -->
    <Color x:Key="BgPrimary">#090909</Color>
    <Color x:Key="BgSidebar">#0C0C0C</Color>
    <Color x:Key="BgCard">#111111</Color>
    <Color x:Key="BgCardHover">#181818</Color>
    <Color x:Key="BgInput">#0D0D0D</Color>
    <Color x:Key="BgElement">#1A1A1A</Color>
    <Color x:Key="BgActiveRow">#1C1C1C</Color>

    <!-- ── Text ─────────────────────────────────────────── -->
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#888888</Color>
    <Color x:Key="TextMuted">#555555</Color>

    <!-- ── Accent — 单色灰蓝，克制 ─────────────────────── -->
    <Color x:Key="Accent">#5B8DEF</Color>
    <Color x:Key="AccentHover">#6B9AFF</Color>
    <Color x:Key="AccentDim">#2A3A5A</Color>

    <!-- ── Borders — 极淡，仅作分隔线 ─────────────────── -->
    <Color x:Key="BorderSubtle">#1C1C1C</Color>
    <Color x:Key="BorderFocus">#5B8DEF</Color>

    <!-- ── 状态色 ──────────────────────────────────────── -->
    <Color x:Key="AccentGreen">#4CAF82</Color>
    <Color x:Key="AccentOrange">#D4956A</Color>
    <Color x:Key="HeartInactive">#3A3A3A</Color>
    <Color x:Key="SliderTrackOverlay">#1FFFFFFF</Color>
    <Color x:Key="SongRowBorder">#1A1A1A</Color>
    <Color x:Key="PlayerBarBg">#0C0C0C</Color>
    <Color x:Key="BgElement2">#161616</Color>

    <!-- ── Brushes ─────────────────────────────────────── -->
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}" />
    <SolidColorBrush x:Key="BgSidebarBrush" Color="{StaticResource BgSidebar}" />
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}" />
    <SolidColorBrush x:Key="BgCardHoverBrush" Color="{StaticResource BgCardHover}" />
    <SolidColorBrush x:Key="BgInputBrush" Color="{StaticResource BgInput}" />
    <SolidColorBrush x:Key="BgElementBrush" Color="{StaticResource BgElement}" />
    <SolidColorBrush x:Key="BgActiveRowBrush" Color="{StaticResource BgActiveRow}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}" />
    <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDim}" />

    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}" />
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocus}" />

    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}" />
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrange}" />
    <SolidColorBrush x:Key="BgTableHeaderBrush" Color="#0D0D0D" />
    <SolidColorBrush x:Key="BgActiveRowBrush2" Color="{StaticResource BgActiveRow}" />
    <SolidColorBrush x:Key="PlayerBarBgBrush" Color="{StaticResource PlayerBarBg}" />
    <SolidColorBrush x:Key="BgElement2Brush" Color="{StaticResource BgElement2}" />

    <!-- 去掉所有渐变，只保留单色按钮背景 -->
    <SolidColorBrush x:Key="PlayButtonBackground" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="SliderTrackBgBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="SliderVolumeFillBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="SliderTrackOverlayBrush" Color="{StaticResource SliderTrackOverlay}" />
    <SolidColorBrush x:Key="HeartInactiveBrush" Color="{StaticResource HeartInactive}" />
    <SolidColorBrush x:Key="SongRowBorderBrush" Color="{StaticResource SongRowBorder}" />

    <!-- ── 尺寸 ───────────────────────────────────────── -->
    <x:Double x:Key="IconButtonSize">36</x:Double>
    <x:Double x:Key="IconButtonSizeLarge">56</x:Double>
    <x:Double x:Key="IconButtonSizeSmall">30</x:Double>
    <x:Double x:Key="IconButtonSizeTiny">22</x:Double>

    <CornerRadius x:Key="DefaultCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="SmallCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="TinyCornerRadius">3</CornerRadius>

    <x:Double x:Key="FontSizeSmall">11</x:Double>
    <x:Double x:Key="FontSizeNormal">13</x:Double>
    <x:Double x:Key="FontSizeMedium">14</x:Double>
    <x:Double x:Key="FontSizeLarge">16</x:Double>
    <x:Double x:Key="FontSizeXLarge">18</x:Double>
    <x:Double x:Key="FontSizeTitle">26</x:Double>

    <FontFamily x:Key="FontFamilyPrimary">Inter</FontFamily>
    <FontFamily x:Key="FontFamilyMono">Consolas, monospace</FontFamily>

    <!-- ── Control Themes ─────────────────────────────── -->

    <ControlTheme x:Key="OutlineButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{StaticResource BgCardHoverBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="SidebarButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      Content="{TemplateBinding Content}" />
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{StaticResource BgCardHoverBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="^:selected">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="TitleBarButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="#1AFFFFFF" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="TitleBarCloseButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="#E63946" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="CircleIconButtonTheme" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource IconButtonSize}" />
        <Setter Property="Height" Value="{StaticResource IconButtonSize}" />
        <Setter Property="Background" Value="{StaticResource BgElementBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="0" />
    </ControlTheme>

    <ControlTheme x:Key="CircleIconButtonLargeTheme" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource IconButtonSizeLarge}" />
        <Setter Property="Height" Value="{StaticResource IconButtonSizeLarge}" />
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="0" />
    </ControlTheme>

    <ControlTheme x:Key="CircleIconButtonSmallTheme" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource IconButtonSizeSmall}" />
        <Setter Property="Height" Value="{StaticResource IconButtonSizeSmall}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="15" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </ControlTheme>

    <ControlTheme x:Key="TransparentIconButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="CornerRadius" Value="6" />
    </ControlTheme>

    <ControlTheme x:Key="SidebarIconButtonTheme" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource IconButtonSize}" />
        <Setter Property="Height" Value="{StaticResource IconButtonSize}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </ControlTheme>

    <ControlTheme x:Key="CardButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgElementBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{StaticResource BgCardHoverBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="PrimaryButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="White" />
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="SecondaryButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgCardHoverBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </ControlTheme>

    <ControlTheme x:Key="AccentButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="White" />
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="IconTextButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="CornerRadius" Value="6" />
    </ControlTheme>

    <ControlTheme x:Key="ToolbarButtonTheme" TargetType="Button">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="0" />
    </ControlTheme>

    <ControlTheme x:Key="PlayerIconButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="CornerRadius" Value="6" />
    </ControlTheme>

    <ControlTheme x:Key="PlayerCircleButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="SongRowButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="CornerRadius" Value="17" />
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </ControlTheme>

    <ControlTheme x:Key="SongListItemTheme" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BgCardHoverBrush}" />
        </Style>
        <Style Selector="^:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BgActiveRowBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="QueueListItemTheme" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BgCardHoverBrush}" />
        </Style>
        <Style Selector="^:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="TabRadioButtonTheme" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
        <Style Selector="^:checked">
            <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        </Style>
        <Style Selector="^:pointerover">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>
    </ControlTheme>

    <!-- CardTheme — 无边框，只保留背景和圆角 -->
    <ControlTheme x:Key="CardTheme" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgCardBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20" />
    </ControlTheme>

    <ControlTheme x:Key="CardHoverTheme" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgCardHoverBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Cursor" Value="Hand" />
    </ControlTheme>

    <ControlTheme x:Key="InputBorderTheme" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgInputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
    </ControlTheme>

    <!-- Progress Slider — 单色轨 -->
    <ControlTheme x:Key="MusicProgressSliderTheme" TargetType="Slider">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Height="20" VerticalAlignment="Center"
                        Background="Transparent" IsHitTestVisible="True">
                    <Grid VerticalAlignment="Center">
                        <Border Name="TrackBackground" Height="3"
                                VerticalAlignment="Center"
                                Background="{StaticResource SliderTrackBgBrush}"
                                CornerRadius="2" IsHitTestVisible="False" />
                        <Track Name="PART_Track" VerticalAlignment="Center"
                               IsDirectionReversed="False"
                               Maximum="{TemplateBinding Maximum}"
                               Minimum="{TemplateBinding Minimum}"
                               Orientation="Horizontal"
                               Value="{TemplateBinding Value, Mode=TwoWay}">
                            <Track.DecreaseButton>
                                <RepeatButton Focusable="False" IsHitTestVisible="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border Height="3" VerticalAlignment="Center"
                                                    Background="{StaticResource AccentBrush}" CornerRadius="2" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseButton>
                            <Track.IncreaseButton>
                                <RepeatButton Focusable="False" IsHitTestVisible="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseButton>
                            <Track.Thumb>
                                <Thumb Width="10" Height="10" Focusable="False">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Width="10" Height="10" Background="{StaticResource AccentBrush}"
                                                    CornerRadius="5" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="VolumeControlSliderTheme" TargetType="Slider">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Height="16" VerticalAlignment="Center" Background="Transparent">
                    <Grid VerticalAlignment="Center">
                        <Border Name="TrackBackground" Height="3"
                                VerticalAlignment="Center"
                                Background="{StaticResource SliderTrackBgBrush}"
                                CornerRadius="2" />
                        <Track Name="PART_Track" VerticalAlignment="Center"
                               IsDirectionReversed="False"
                               Maximum="{TemplateBinding Maximum}"
                               Minimum="{TemplateBinding Minimum}"
                               Orientation="Horizontal"
                               Value="{TemplateBinding Value, Mode=TwoWay}">
                            <Track.DecreaseButton>
                                <RepeatButton Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border Height="3" VerticalAlignment="Center"
                                                    Background="{StaticResource TextSecondaryBrush}" CornerRadius="2" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseButton>
                            <Track.IncreaseButton>
                                <RepeatButton Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseButton>
                            <Track.Thumb>
                                <Thumb Width="8" Height="8" Focusable="False">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Width="8" Height="8" Background="{StaticResource TextSecondaryBrush}"
                                                    CornerRadius="4" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

</ResourceDictionary>
