<UserControl
    x:Class="LocalMusicPlayer.Controls.LyricsLineControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">

    <Border Margin="16,0,16,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="LyricsTextBlockBase"
                Grid.Row="1"
                Margin="0,2"
                HorizontalAlignment="Center"
                FontSize="32"
                FontWeight="Bold"
                Foreground="White"
                Opacity="0.5"
                TextAlignment="Center"
                TextWrapping="Wrap" />

            <Grid
                x:Name="HighlightContainer"
                Grid.Row="1"
                Margin="0,2"
                HorizontalAlignment="Center"
                ClipToBounds="True">
                <TextBlock
                    x:Name="LyricsTextBlock"
                    FontSize="32"
                    FontWeight="Bold"
                    Foreground="White"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </Grid>

            <TextBlock
                x:Name="LyricsTransTextBlock"
                Grid.Row="2"
                Margin="0,2"
                HorizontalAlignment="Center"
                FontSize="24"
                FontWeight="Bold"
                Foreground="White"
                IsVisible="False"
                Opacity="0.5"
                TextAlignment="Center"
                TextWrapping="Wrap" />
        </Grid>
    </Border>
</UserControl>
